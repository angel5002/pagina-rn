---
interface Props {
  /** Spotify track ID (the part after /track/ in the URL) */
  spotify?: string;
  /** YouTube video ID (the v= param) */
  youtube?: string;
  /** Optional title shown above the player */
  title?: string;
  /** Optional eyebrow above the title (default: "Banda sonora") */
  eyebrow?: string;
  /** Optional context line — why this song was picked */
  note?: string;
}

const {
  spotify,
  youtube,
  title,
  eyebrow = 'Banda sonora',
  note
} = Astro.props;

if (!spotify && !youtube) {
  throw new Error('<Music /> requires either spotify="..." or youtube="..."');
}

const provider = spotify ? 'spotify' : 'youtube';

const embedUrl = spotify
  ? `https://open.spotify.com/embed/track/${spotify}?utm_source=generator&theme=0`
  : `https://www.youtube-nocookie.com/embed/${youtube}?rel=0&modestbranding=1`;

const playerHeight = spotify ? 152 : 0; // youtube uses aspect-ratio
---

<aside class={`music music--${provider}`} aria-label="Reproductor de música">
  <header class="music__head">
    <span class="music__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 18V5l12-2v13"></path>
        <circle cx="6" cy="18" r="3"></circle>
        <circle cx="18" cy="16" r="3"></circle>
      </svg>
    </span>
    <div class="music__meta">
      <p class="music__eyebrow">{eyebrow}</p>
      {title && <p class="music__title">{title}</p>}
      {note && <p class="music__note">{note}</p>}
    </div>
  </header>

  <div class={`music__frame music__frame--${provider}`}>
    <iframe
      src={embedUrl}
      title={title ?? 'Reproductor de música'}
      loading="lazy"
      allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
      allowfullscreen
      style={spotify ? `height: ${playerHeight}px;` : undefined}
    ></iframe>
  </div>
</aside>
