---
const base = import.meta.env.BASE_URL;
const link = (path: string) =>
  base.endsWith('/') ? `${base}${path.replace(/^\//, '')}` : `${base}${path}`;

const navItems = [
  { label: 'Inicio', href: link('') },
  { label: 'Semanas', href: link('#semanas') },
  { label: 'Equipo', href: link('#equipo') },
  { label: 'Curso', href: link('#curso') }
];
---

<header class="topbar">
  <div class="container topbar__inner">
    <a class="topbar__brand" href={link('')} aria-label="Realidad Nacional — inicio">
      <span class="topbar__brand-mark" aria-hidden="true"></span>
      <span>Realidad Nacional</span>
    </a>

    <nav class="topbar__nav" data-menu-target aria-label="Navegación principal">
      {navItems.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>

    <button
      class="topbar__menu-btn"
      type="button"
      data-menu-toggle
      aria-controls="primary-nav"
      aria-expanded="false"
      aria-label="Abrir menú"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </div>
</header>
