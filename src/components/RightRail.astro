---
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const trimmed = base.endsWith('/') ? base.slice(0, -1) : base;
const weekHref = (id: string) => `${trimmed}/semanas/${id}`;

const weeks = (await getCollection('weeks')).sort(
  (a, b) => b.data.order - a.data.order
);
const recent = weeks.slice(0, 4);

const tags = [
  'Módulo 1',
  'República',
  'Democracia',
  'Economía',
  'Memoria',
  'CVR',
  'Derechos',
  'Castilla'
];
---

<aside class="right-rail" aria-label="Información complementaria">
  <section class="rail__section">
    <h3 class="rail__heading">Recientes</h3>
    <ul class="rail__list">
      {recent.map((w) => (
        <li>
          <a href={weekHref(w.id)}>{w.data.title}</a>
        </li>
      ))}
    </ul>
  </section>

  <section class="rail__section">
    <h3 class="rail__heading">Etiquetas</h3>
    <div class="tag-cloud">
      {tags.map((t) => (
        <span class="tag-pill">{t}</span>
      ))}
    </div>
  </section>

  <section class="rail__section">
    <h3 class="rail__heading">El curso</h3>
    <ul class="rail__list">
      <li><span style="color: var(--text-muted-color);">Realidad Nacional</span></li>
      <li><span style="color: var(--text-muted-color);">HUM 204 · 2026‑1</span></li>
      <li><span style="color: var(--text-muted-color);">UCSUR · Cursos Básicos</span></li>
    </ul>
  </section>
</aside>
