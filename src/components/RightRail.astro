---
import { getCollection } from 'astro:content';
import { slugify, withBase } from '../lib/paths';

const base = import.meta.env.BASE_URL;

const weeks = (await getCollection('weeks')).sort(
  (a, b) => b.data.order - a.data.order
);
const recent = weeks.slice(0, 5);

const counts = new Map<string, { label: string; count: number }>();
for (const w of weeks) {
  for (const tag of w.data.tags ?? []) {
    const slug = slugify(tag);
    if (!slug) continue;
    const existing = counts.get(slug);
    if (existing) existing.count += 1;
    else counts.set(slug, { label: tag, count: 1 });
  }
}
const tags = Array.from(counts.entries())
  .map(([slug, info]) => ({ slug, ...info }))
  .sort((a, b) => b.count - a.count || a.label.localeCompare(b.label))
  .slice(0, 10);
---

<aside class="right-rail" aria-label="Información complementaria">
  <section class="rail__section">
    <h3 class="rail__heading">Recientes</h3>
    <ul class="rail__list">
      {recent.map((w) => (
        <li>
          <a href={withBase(base, `semanas/${w.id}`)}>{w.data.title}</a>
        </li>
      ))}
    </ul>
  </section>

  <section class="rail__section">
    <h3 class="rail__heading">Etiquetas</h3>
    <div class="tag-cloud">
      {tags.map((t) => (
        <a class="tag-pill" href={withBase(base, `tags/${t.slug}`)}>
          <span>{t.label}</span>
        </a>
      ))}
    </div>
    <p class="rail__more">
      <a href={withBase(base, 'tags')}>Ver todas →</a>
    </p>
  </section>

  <section class="rail__section">
    <h3 class="rail__heading">El curso</h3>
    <ul class="rail__list rail__list--muted">
      <li>Realidad Nacional</li>
      <li>HUM 204 · 2026‑1</li>
      <li>UCSUR · Cursos Básicos</li>
    </ul>
  </section>
</aside>
