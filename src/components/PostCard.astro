---
interface Props {
  href: string;
  title: string;
  excerpt: string;
  date: string;
  topic: string;
  pinned?: boolean;
}

const { href, title, excerpt, date, topic, pinned = false } = Astro.props;
---

<a class="post-card" href={href}>
  <div>
    <p class="post-card__title">{title}</p>
    <p class="post-card__excerpt">{excerpt}</p>
    <div class="post-card__meta">
      <span class="post-card__meta-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="16" y1="2" x2="16" y2="6"></line>
          <line x1="8" y1="2" x2="8" y2="6"></line>
          <line x1="3" y1="10" x2="21" y2="10"></line>
        </svg>
        <span>{date}</span>
      </span>
      <span class="post-card__meta-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
        </svg>
        <span>{topic}</span>
      </span>
      {pinned && (
        <span class="post-card__pin" aria-label="Destacado">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M9 4v8L5 16v2h6v6l1-3v-3h6v-2l-4-4V4h2V2H7v2h2z"></path>
          </svg>
        </span>
      )}
    </div>
  </div>
</a>
