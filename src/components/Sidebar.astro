---
import { Image } from 'astro:assets';
import logo from '../assets/images/varios/Universidad_Cientifica_logo.png';
import { withBase } from '../lib/paths';

const base = import.meta.env.BASE_URL;
const baseTrim = base.endsWith('/') ? base.slice(0, -1) : base;
const current = (Astro.url.pathname.replace(/\/+$/, '') || '/').toLowerCase();

function isActive(targetPath: string): boolean {
  // targetPath uses no trailing slash; '' means home.
  const target = targetPath
    ? `${baseTrim}/${targetPath}`.toLowerCase()
    : `${baseTrim}` || '/';
  if (target === '' || target === '/') {
    return current === '/' || current === baseTrim.toLowerCase();
  }
  return current === target || current.startsWith(`${target}/`);
}

const navItems = [
  { key: 'home',    label: 'Inicio',         href: withBase(base, ''),        target: '',         icon: 'home' },
  { key: 'semanas', label: 'Semanas',        href: withBase(base, 'semanas'), target: 'semanas',  icon: 'list' },
  { key: 'tags',    label: 'Etiquetas',      href: withBase(base, 'tags'),    target: 'tags',     icon: 'tag' },
  { key: 'equipo',  label: 'Equipo',         href: withBase(base, 'equipo'),  target: 'equipo',   icon: 'users' },
  { key: 'sobre',   label: 'Sobre el curso', href: withBase(base, 'sobre'),   target: 'sobre',    icon: 'info' }
];
---

<aside id="sidebar" aria-label="Navegación principal">
  <div class="sidebar__profile">
    <a href={withBase(base, '')} class="sidebar__avatar-link" aria-label="Realidad Nacional · Inicio">
      <span class="sidebar__avatar">
        <Image
          src={logo}
          alt="Universidad Científica del Sur"
          widths={[176, 220]}
          sizes="88px"
        />
      </span>
    </a>
    <a href={withBase(base, '')} class="sidebar__title">Realidad Nacional</a>
    <p class="sidebar__subtitle">Blog del curso HUM 204 — UCSUR · 2026‑1</p>
  </div>

  <ul class="sidebar__nav">
    {navItems.map((item) => (
      <li class:list={[{ 'is-active': isActive(item.target) }]}>
        <a href={item.href}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            {item.icon === 'home' && (
              <>
                <path d="M3 11.5L12 4l9 7.5"></path>
                <path d="M5 10v10h14V10"></path>
              </>
            )}
            {item.icon === 'list' && (
              <>
                <line x1="8" y1="6" x2="21" y2="6"></line>
                <line x1="8" y1="12" x2="21" y2="12"></line>
                <line x1="8" y1="18" x2="21" y2="18"></line>
                <circle cx="4" cy="6" r="1"></circle>
                <circle cx="4" cy="12" r="1"></circle>
                <circle cx="4" cy="18" r="1"></circle>
              </>
            )}
            {item.icon === 'tag' && (
              <>
                <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                <line x1="7" y1="7" x2="7.01" y2="7"></line>
              </>
            )}
            {item.icon === 'users' && (
              <>
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
              </>
            )}
            {item.icon === 'info' && (
              <>
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" y1="16" x2="12" y2="12"></line>
                <line x1="12" y1="8" x2="12.01" y2="8"></line>
              </>
            )}
          </svg>
          <span>{item.label}</span>
        </a>
      </li>
    ))}
  </ul>

  <div class="sidebar__bottom">
    <button
      class="sidebar__icon-btn"
      type="button"
      data-theme-toggle
      aria-label="Cambiar tema"
      title="Cambiar tema (claro/oscuro)"
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="4"></circle>
        <path d="M12 3v2M12 19v2M3 12h2M19 12h2M5.6 5.6l1.4 1.4M17 17l1.4 1.4M5.6 18.4L7 17M17 7l1.4-1.4"></path>
      </svg>
    </button>
    <span class="sidebar__dot" aria-hidden="true"></span>
    <a class="sidebar__icon-btn" href="https://github.com/angel5002/pagina-rn" target="_blank" rel="noreferrer" aria-label="Repositorio en GitHub">
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 0.5C5.65 0.5 0.5 5.65 0.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56 0-.27-.01-.99-.02-1.94-3.2.7-3.87-1.54-3.87-1.54-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.69.08-.69 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.24 3.34.95.1-.74.4-1.24.73-1.53-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.15 1.18A10.96 10.96 0 0 1 12 6.84c.97 0 1.95.13 2.86.39 2.18-1.49 3.14-1.18 3.14-1.18.62 1.58.23 2.75.11 3.04.74.81 1.18 1.84 1.18 3.1 0 4.42-2.7 5.39-5.27 5.68.41.36.78 1.06.78 2.13 0 1.54-.01 2.78-.01 3.16 0 .31.21.67.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35 0.5 12 0.5z"/>
      </svg>
    </a>
    <a class="sidebar__icon-btn" href="mailto:ong.mpsa@gmail.com" aria-label="Correo">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
        <polyline points="22,6 12,13 2,6"></polyline>
      </svg>
    </a>
  </div>
</aside>
