---
interface Props {
  variant?: 'coral' | 'forest' | 'dark';
  eyebrow?: string;
  title: string;
  body?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  variant = 'coral',
  eyebrow,
  title,
  body,
  ctaLabel,
  ctaHref
} = Astro.props;
---

<section class={`signature-card signature-card--${variant} reveal`}>
  {eyebrow && (
    <span
      class="eyebrow"
      style="color: rgba(255,255,255,0.85);"
    >
      {eyebrow}
    </span>
  )}
  <h2>{title}</h2>
  {body && <p>{body}</p>}
  {ctaLabel && ctaHref && (
    <div>
      <a class="btn btn--secondary" href={ctaHref}>{ctaLabel}</a>
    </div>
  )}
</section>
