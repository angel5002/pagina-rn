---
import '../styles/global.scss';
import Sidebar from '../components/Sidebar.astro';
import TopBar from '../components/TopBar.astro';
import RightRail from '../components/RightRail.astro';

interface Props {
  title: string;
  description?: string;
  crumbs?: { label: string; href?: string }[];
  hideRail?: boolean;
}

const {
  title,
  description = 'Blog del curso de Realidad Nacional — HUM 204, Universidad Científica del Sur, ciclo 2026‑1.',
  crumbs,
  hideRail = false
} = Astro.props;

const base = import.meta.env.BASE_URL;
const favicon = `${base.replace(/\/$/, '')}/favicon.svg`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={favicon} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <script is:inline>
      // Read theme preference before paint to avoid FOUC.
      try {
        const stored = localStorage.getItem('theme');
        const prefers = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = stored || (prefers ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      } catch (_e) {}
    </script>
  </head>
  <body>
    <div class="app">
      <Sidebar />
      <div class="scrim" data-scrim aria-hidden="true"></div>
      <div id="main-wrapper">
        <TopBar crumbs={crumbs} />
        <div class="main-area">
          <main class="main-column" id="main">
            <slot />
          </main>
          {!hideRail && <RightRail />}
        </div>
      </div>
    </div>

    <button
      class="back-to-top"
      type="button"
      data-back-to-top
      aria-label="Volver al inicio"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="12" y1="19" x2="12" y2="5"></line>
        <polyline points="5 12 12 5 19 12"></polyline>
      </svg>
    </button>

    <script>
      import { initSidebarDrawer } from '../scripts/sidebar-drawer';
      import { initThemeToggle } from '../scripts/theme-toggle';
      import { initScrollReveal } from '../scripts/scroll-reveal';
      import { initBackToTop } from '../scripts/back-to-top';
      import { initSearch } from '../scripts/search';

      initThemeToggle();
      initSidebarDrawer();
      initScrollReveal();
      initBackToTop();
      initSearch();
    </script>
  </body>
</html>
