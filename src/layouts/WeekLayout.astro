---
import BaseLayout from './BaseLayout.astro';

interface Props {
  number: string;
  title: string;
  topic: string;
  date: string;
  authors?: string[];
}

const { number, title, topic, date, authors = [] } = Astro.props;
---

<BaseLayout title={`${title} · Realidad Nacional`} description={topic}>
  <article>
    <header class="post-header">
      <div class="container">
        <p class="eyebrow post-header__eyebrow">{number} · {topic}</p>
        <h1 class="post-header__title">{title}</h1>
        <div class="post-header__meta">
          <span><strong>Sesión:</strong> {date}</span>
          {authors.length > 0 && (
            <span><strong>Equipo:</strong> {authors.join(' · ')}</span>
          )}
        </div>
      </div>
    </header>

    <section class="section">
      <div class="container">
        <div class="prose">
          <slot />
        </div>
      </div>
    </section>
  </article>
</BaseLayout>
