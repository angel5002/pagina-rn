---
import BaseLayout from './BaseLayout.astro';

interface Props {
  number: string;
  title: string;
  topic: string;
  date: string;
  authors?: string[];
}

const { number, title, topic, date, authors = [] } = Astro.props;

const crumbs = [
  { label: 'Semanas' },
  { label: number }
];
---

<BaseLayout title={`${title} · Realidad Nacional`} description={topic} crumbs={crumbs}>
  <article class="post">
    <header class="post__header">
      <p class="post__eyebrow">{number} · {topic}</p>
      <h1 class="post__title">{title}</h1>
      <div class="post__meta">
        <span><strong>Sesión:</strong> {date}</span>
        {authors.length > 0 && (
          <span><strong>Equipo:</strong> {authors.join(' · ')}</span>
        )}
      </div>
    </header>

    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>
