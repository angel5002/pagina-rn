---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SignatureCard from '../components/SignatureCard.astro';
import WeekCard from '../components/WeekCard.astro';

const weeks = (await getCollection('weeks')).sort(
  (a, b) => a.data.order - b.data.order
);

const base = import.meta.env.BASE_URL;
const weekHref = (id: string) => {
  const trimmed = base.endsWith('/') ? base.slice(0, -1) : base;
  return `${trimmed}/semanas/${id}`;
};

const courseMeta = [
  { label: 'CÓDIGO', value: 'HUM 204' },
  { label: 'CICLO', value: '2026‑1' },
  { label: 'DOCENTE', value: 'Auroni Cenepo Gutiérrez' },
  { label: 'DEPARTAMENTO', value: 'Cursos Básicos · UCSUR' }
];

const team = [
  'Abanto Huertas, Leonardo Manuel',
  'Lopez Chambillo, Gabriela Nicol',
  'Vargas Flores, Angel Jaime',
  'Vergara Carpio, Grecia Hadid'
];
---

<BaseLayout title="Realidad Nacional · Blog del curso HUM 204">
  <!-- Hero -->
  <section class="hero">
    <div class="container reveal">
      <p class="eyebrow hero__eyebrow">HUM 204 · Universidad Científica del Sur · 2026‑1</p>
      <h1 class="hero__title">El Perú leído semana a semana.</h1>
      <p class="lead hero__lead">
        Este es el blog del equipo del curso de Realidad Nacional. Aquí publicamos,
        sesión a sesión, las lecturas, debates y entregables grupales que recorren
        los ejes histórico, social, cultural, económico y político del país.
      </p>
      <div class="hero__actions">
        <a class="btn btn--primary" href="#semanas">Ver las semanas</a>
        <a class="btn btn--secondary" href="#curso">Sobre el curso</a>
      </div>
    </div>
  </section>

  <!-- Signature card: módulo actual -->
  <section class="section-tight" id="modulo">
    <div class="container">
      <SignatureCard
        variant="coral"
        eyebrow="Módulo en curso"
        title="Módulo 1 · El Perú y sus orígenes"
        body="Identificamos información confiable sobre la evolución política, económica y social del Perú durante la formación de la República y sus principales procesos históricos, produciendo nuestras propias reflexiones."
        ctaLabel="Empezar por la Semana 01"
        ctaHref={weekHref('semana-01')}
      />
    </div>
  </section>

  <!-- Lista de semanas -->
  <section class="section" id="semanas">
    <div class="container">
      <p class="eyebrow" style="margin-bottom: var(--space-md);">Semanas publicadas</p>
      <h2 style="margin-bottom: var(--space-xl); max-width: 22ch;">
        Cuatro sesiones, una lectura del Perú republicano.
      </h2>

      <div class="week-grid reveal-stagger">
        {weeks.map((week) => (
          <WeekCard
            number={week.data.number}
            title={week.data.title}
            date={week.data.date}
            href={weekHref(week.id)}
            surface={week.data.surface}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Cream callout: equipo -->
  <section class="section-tight" id="equipo">
    <div class="container reveal">
      <div class="cream-callout">
        <p class="eyebrow" style="margin-bottom: var(--space-sm);">Equipo</p>
        <h3 class="callout-title">
          Cuatro lectores, una conversación que se publica en abierto.
        </h3>
        <div class="team-grid">
          {team.map((member) => <p>{member}</p>)}
        </div>
      </div>
    </div>
  </section>

  <!-- Sobre el curso -->
  <section class="section" id="curso">
    <div class="container">
      <div class="course-grid">
        <div class="reveal">
          <p class="eyebrow" style="margin-bottom: var(--space-md);">Sobre el curso</p>
          <h2 style="margin-bottom: var(--space-md);">
            Realidad Nacional es un curso teórico que pide tomar postura.
          </h2>
          <p style="font-size: 16px; line-height: 1.6; color: var(--color-body);">
            Su propósito es analizar la realidad peruana a lo largo de su experiencia
            histórica, comprendiendo el país a través de sus ejes histórico, social,
            cultural, económico y político. El curso recorre cuatro módulos: Perú y
            sus orígenes, Perú institucional, Perú económico y social, y la visión
            de un futuro sostenible.
          </p>
        </div>
        <div class="reveal">
          <div class="course-meta">
            {courseMeta.map((row, idx) => (
              <>
                {idx > 0 && <hr class="divider" />}
                <div class="course-meta__row">
                  <p>{row.label}</p>
                  <p>{row.value}</p>
                </div>
              </>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA banner -->
  <section class="section-tight">
    <div class="container reveal">
      <div class="cta-band-light">
        <div>
          <p class="eyebrow" style="margin-bottom: var(--space-sm);">Próxima sesión</p>
          <h3 style="font-size: 28px; line-height: 1.25; max-width: 24ch; margin: 0;">
            La Semana 5 trae la primera evaluación continua.
          </h3>
        </div>
        <a class="btn btn--primary" href={weekHref('semana-04')}>Repasar la última semana</a>
      </div>
    </div>
  </section>
</BaseLayout>
